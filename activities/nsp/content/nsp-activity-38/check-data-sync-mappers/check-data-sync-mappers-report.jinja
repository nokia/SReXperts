---
name: check-data-sync-mappers-report
template: |
  <!DOCTYPE html>
  <html>
    <head>
      <style>
        :root {
          --page-bg: #0f172a;
          --page-text: #f8fafc;
          --muted-text: #cbd5e1;
          --headline: #7cc4ff;
          --surface-bg: #111827;
          --surface-elevated: #172033;
          --surface-border: #334155;
          --table-head-bg: #243146;
          --table-row-alt: #0b1220;
          --surface-shadow: rgba(2, 6, 23, 0.35);
          --status-success: #6ee7b7;
          --status-failure: #fca5a5;
          --status-plan: #fdba74;
          --status-neutral: #cbd5e1;
        }
        * {
          box-sizing: border-box;
        }
        body.font-nokia-pure-text {
          font-family: "NokiaPure", sans-serif;
          margin: 0;
          padding: 16px;
          background-color: var(--page-bg);
          color: var(--page-text);
        }
        .headline {
          color: var(--headline);
          font-size: 20px;
          margin: 0 0 16px 0;
          text-align: center;
        }
        .overall-result {
          margin: 0 auto 16px auto;
          padding: 12px 16px;
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
          max-width: 1100px;
          background-color: var(--surface-elevated);
          border: 1px solid var(--surface-border);
          border-radius: 10px;
          box-shadow: 0 10px 24px var(--surface-shadow);
        }
        .overall-bullet {
          display: inline-block;
          width: 12px;
          height: 12px;
          border-radius: 50%;
          vertical-align: middle;
          flex-shrink: 0;
        }
        .overall-message {
          font-size: 15px;
          color: var(--muted-text);
        }
        .main-content {
          padding: 6px 0;
          display: flex;
          justify-content: center;
          align-items: center;
        }
        table {
          width: min(100%, 1100px);
          font-size: 14px;
          text-align: left;
          border-collapse: collapse;
          background-color: var(--surface-bg);
          color: var(--page-text);
          border: 1px solid var(--surface-border);
          border-radius: 10px;
          overflow: hidden;
          box-shadow: 0 10px 24px var(--surface-shadow);
        }
        thead {
          background-color: var(--table-head-bg);
        }
        tbody tr:nth-child(even) {
          background-color: var(--table-row-alt);
        }
        th, td {
          padding: 10px;
          border: 1px solid var(--surface-border);
        }
        th {
          color: var(--muted-text);
          font-weight: 600;
        }
        .status-success { color: var(--status-success); }
        .status-failure { color: var(--status-failure); }
        .status-plan { color: var(--status-plan); }
        .status-neutral { color: var(--status-neutral); }
      </style>
    </head>
    <body class="font-nokia-pure-text">
      <p class="headline">Check Data Sync Mappers</p>
      <div class="overall-result">
        <span class="overall-bullet" style="background-color: {{ overall_color }}"></span>
        <span class="overall-message">{{ overall_message | safe }}</span>
      </div>
      <div class="main-content">
        <table>
          <thead>
            <tr>
              {%- if show_node_column %}
              <th>Node</th>
              {%- endif %}
              <th>Check</th>
              <th>Status</th>
              <th>Class / Details</th>
            </tr>
          </thead>
          <tbody>
  {%- for row in rows -%}
            <tr>
              {%- if show_node_column %}
              <td>{{ row.node | safe }}</td>
              {%- endif %}
              <td>{{ row.service | safe }}</td>
              <td class="{{ row.status_class }}">{{ row.status | safe }}</td>
              <td>{{ row.error_message | safe }}</td>
            </tr>
  {%- endfor -%}
          </tbody>
        </table>
      </div>
    </body>
  </html>
