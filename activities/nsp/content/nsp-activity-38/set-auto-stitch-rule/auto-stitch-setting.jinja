name: auto-stitch-setting
version: 1.0.0
template: |
  <!DOCTYPE html>
  <html>
    <head>
      <style>
        .font-nokia-pure-text {
          font-family: "NokiaPure", sans-serif;
        }
        .headline {
          color: #183693;
          font-size: 20px;
          margin: 0px 0px 15px 0px;
          text-align: center;
        }
        .main-content {
          padding: 6px;
          display: flex;
          justify-content: center;
          align-items: center;
        }
        table {
          width: 60%;
          font-size: 15px;
          text-align: left;
          border-collapse: collapse;
        }
        thead {
          background-color: #eaeaea;
        }
        td {
          padding: 10px;
        }
        tr td:last-child {
          text-align: right;
        }
        .service {
          border-top: 1px solid #aeaeae;
          border-bottom: 1px solid #aeaeae;
        }
        .algo {
          margin-left: 10px;
          padding: 6px 10px;
          border-left: solid gray 1px;
        }
        .admin-state {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          border: 1px solid transparent;
          background-color: #e7e7e7;
          font-family: "NokiaPure", sans-serif;
          border-radius: 4px;
          padding: 2px 8px;
          font-size: 14px;
        }
        .admin-state.success {
          background-color: #228B22;
          color: white;
        }
      </style>
    </head>
    <body>
      <p class="headline">Service Auto-Stitch Setting</p>
      <div class="main-content font-nokia-pure-text">
        <table>
          <tbody>
  {%- for entry in config -%}
            <tr class="service">
              <td>{{ entry["service-type"] }}</td>
              <td>
                <span class="admin-state{% if entry['admin-state'] == "unlocked" %} success{% endif %}">
                  {{ entry["admin-state"] }}
                </span>
              </td>
            </tr>
  {%- for algo in entry["algorithm-config"] -%}
            <tr>
              <td><span class="algo">{{ algo.algorithm }}</span></td>
              <td>
                <span class="admin-state{% if algo['admin-state'] == "unlocked" %} success{% endif %}">
                  {{ algo["admin-state"] }}
                </span>
              </td>
            </tr>
  {%- endfor %}
  {%- endfor -%}
          </tbody>
        </table>
      </div>
    </body>
  </html>
