auto lo
iface lo inet loopback
    
auto eth1

# VLAN 1
auto eth1.1
iface eth1.1
    mtu 8700
    address 10.64.40.23/24
    address fd00:fde8:0:40::23/64
    post-up ip r a 10.0.0.0/8 via 10.64.40.1 dev eth1.1
    post-up ip -6 r a fd00:fde8::/32 via fd00:fde8:0:40::1 dev eth1.1

# VLAN 101
auto eth1.2101
iface eth1.2101
    mtu 8700
    address 192.168.40.23/24
    address fd00:ffdd:0:40::23/64
    post-up ip r a 192.168.0.0/16 via 192.168.40.1 dev eth1.2101
    post-up ip -6 r a fd00:ffdd::/32 via fd00:ffdd:0:40::1 dev eth1.2101

# VLAN 200 - SRL Ansible
auto eth1.2200
iface eth1.2200
    mtu 8700
    address 10.65.45.23/24
    post-up ip r a 10.65.0.0/16 via 10.65.45.1 dev eth1.2200
